{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["types.d.ts"],
  "tsconfig": "docs-tooling/tsconfig.json",
  "out": "demo/docs",
  "name": "highs-js API reference",
  "readme": "docs/api-reference-home.md",
  "customCss": "docs/typedoc-theme.css",
  "customJs": "docs/typedoc-theme.js",
  "lightHighlightTheme": "github-light-high-contrast",
  "darkHighlightTheme": "github-light-high-contrast",
  "hostedBaseUrl": "https://lovasoa.github.io/highs-js/docs/",
  "navigationLinks": {
    "Demo": "https://lovasoa.github.io/highs-js/",
    "npm": "https://www.npmjs.com/package/highs",
    "GitHub": "https://github.com/lovasoa/highs-js"
  },
  "navigation": {
    "includeCategories": false,
    "includeGroups": true,
    "includeFolders": false,
    "compactFolders": true,
    "excludeReferences": true
  },
  "validation": {
    "notDocumented": true,
    "notExported": true,
    "invalidLink": true
  },
  "requiredToBeDocumented": [
    "Enum",
    "EnumMember",
    "Function",
    "Interface",
    "Property",
    "Method",
    "TypeAlias"
  ],
  "treatValidationWarningsAsErrors": true,
  "githubPages": true,
  "hideGenerator": true
}
