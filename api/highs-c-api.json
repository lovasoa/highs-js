{
  "$schema": "./highs-c-api.schema.json",
  "schemaVersion": 1,
  "header": "HiGHS/highs/interfaces/highs_c_api.h",
  "deprecatedBoundary": "Deprecated methods",
  "statusConvention": {
    "error": -1,
    "ok": 0,
    "warning": 1
  },
  "constantPolicy": {
    "includePattern": "^kHighs",
    "cType": "HighsInt",
    "exposure": "curated-grouped-names",
    "valuePolicy": "exact-number",
    "groups": {
      "status": {
        "error": "kHighsStatusError",
        "ok": "kHighsStatusOk",
        "warning": "kHighsStatusWarning"
      },
      "variableType": {
        "continuous": "kHighsVarTypeContinuous",
        "integer": "kHighsVarTypeInteger",
        "semiContinuous": "kHighsVarTypeSemiContinuous",
        "semiInteger": "kHighsVarTypeSemiInteger",
        "implicitInteger": "kHighsVarTypeImplicitInteger"
      },
      "objectiveSense": {
        "minimize": "kHighsObjSenseMinimize",
        "maximize": "kHighsObjSenseMaximize"
      },
      "matrixFormat": {
        "columnWise": "kHighsMatrixFormatColwise",
        "rowWise": "kHighsMatrixFormatRowwise"
      },
      "hessianFormat": {
        "triangular": "kHighsHessianFormatTriangular",
        "square": "kHighsHessianFormatSquare"
      },
      "optionType": {
        "boolean": "kHighsOptionTypeBool",
        "integer": "kHighsOptionTypeInt",
        "double": "kHighsOptionTypeDouble",
        "string": "kHighsOptionTypeString"
      },
      "infoType": {
        "int64": "kHighsInfoTypeInt64",
        "integer": "kHighsInfoTypeInt",
        "double": "kHighsInfoTypeDouble"
      },
      "solutionStatus": {
        "none": "kHighsSolutionStatusNone",
        "infeasible": "kHighsSolutionStatusInfeasible",
        "feasible": "kHighsSolutionStatusFeasible"
      },
      "basisValidity": {
        "invalid": "kHighsBasisValidityInvalid",
        "valid": "kHighsBasisValidityValid"
      },
      "basisStatus": {
        "lower": "kHighsBasisStatusLower",
        "basic": "kHighsBasisStatusBasic",
        "upper": "kHighsBasisStatusUpper",
        "zero": "kHighsBasisStatusZero",
        "nonbasic": "kHighsBasisStatusNonbasic"
      },
      "callbackType": {
        "logging": "kHighsCallbackLogging",
        "simplexInterrupt": "kHighsCallbackSimplexInterrupt",
        "ipmInterrupt": "kHighsCallbackIpmInterrupt",
        "mipSolution": "kHighsCallbackMipSolution",
        "mipImprovingSolution": "kHighsCallbackMipImprovingSolution",
        "mipLogging": "kHighsCallbackMipLogging",
        "mipInterrupt": "kHighsCallbackMipInterrupt",
        "mipCutPool": "kHighsCallbackMipGetCutPool",
        "mipUserSolution": "kHighsCallbackCallbackMipUserSolution"
      },
      "presolveStatus": {
        "notPresolved": "kHighsPresolveStatusNotPresolved",
        "notReduced": "kHighsPresolveStatusNotReduced",
        "infeasible": "kHighsPresolveStatusInfeasible",
        "unboundedOrInfeasible": "kHighsPresolveStatusUnboundedOrInfeasible",
        "reduced": "kHighsPresolveStatusReduced",
        "reducedToEmpty": "kHighsPresolveStatusReducedToEmpty",
        "timeout": "kHighsPresolveStatusTimeout",
        "nullError": "kHighsPresolveStatusNullError",
        "optionsError": "kHighsPresolveStatusOptionsError",
        "outOfMemory": "kHighsPresolveStatusOutOfMemory"
      },
      "modelStatus": {
        "notSet": "kHighsModelStatusNotset",
        "loadError": "kHighsModelStatusLoadError",
        "modelError": "kHighsModelStatusModelError",
        "presolveError": "kHighsModelStatusPresolveError",
        "solveError": "kHighsModelStatusSolveError",
        "postsolveError": "kHighsModelStatusPostsolveError",
        "empty": "kHighsModelStatusModelEmpty",
        "optimal": "kHighsModelStatusOptimal",
        "infeasible": "kHighsModelStatusInfeasible",
        "unboundedOrInfeasible": "kHighsModelStatusUnboundedOrInfeasible",
        "unbounded": "kHighsModelStatusUnbounded",
        "objectiveBound": "kHighsModelStatusObjectiveBound",
        "objectiveTarget": "kHighsModelStatusObjectiveTarget",
        "timeLimit": "kHighsModelStatusTimeLimit",
        "iterationLimit": "kHighsModelStatusIterationLimit",
        "unknown": "kHighsModelStatusUnknown",
        "solutionLimit": "kHighsModelStatusSolutionLimit",
        "interrupted": "kHighsModelStatusInterrupt"
      },
      "iis": {
        "strategyLight": "kHighsIisStrategyLight",
        "strategyRowPriority": "kHighsIisStrategyFromLpRowPriority",
        "strategyColPriority": "kHighsIisStrategyFromLpColPriority",
        "boundFree": "kHighsIisBoundFree",
        "boundLower": "kHighsIisBoundLower",
        "boundUpper": "kHighsIisBoundUpper",
        "boundBoxed": "kHighsIisBoundBoxed",
        "notInConflict": "kHighsIisStatusNotInConflict",
        "maybeInConflict": "kHighsIisStatusMaybeInConflict",
        "inConflict": "kHighsIisStatusInConflict"
      }
    },
    "excluded": {
      "kHighsMaximumStringLength": "Internal buffer sizing is not a solver semantic.",
      "kHighsCallbackMipDefineLazyConstraints": "This callback type is inert in the bundled HiGHS version."
    }
  },
  "defaults": {
    "rawName": "lowerCamelCase C name without the Highs_ prefix",
    "wasmExport": true,
    "returnPolicy": "status-object",
    "arrayPolicy": "copy-detached"
  },
  "groups": [
    {
      "family": "one-shot",
      "exposure": "raw-runtime",
      "functions": ["Highs_lpCall", "Highs_mipCall", "Highs_qpCall"]
    },
    {
      "family": "ownership",
      "exposure": "internal",
      "functions": ["Highs_create", "Highs_destroy"]
    },
    {
      "family": "runtime",
      "exposure": "raw-runtime",
      "returnPolicy": "direct-value",
      "functions": ["Highs_version", "Highs_versionMajor", "Highs_versionMinor", "Highs_versionPatch", "Highs_githash"]
    },
    {
      "family": "data-io",
      "exposure": "model-data-adapter",
      "functions": ["Highs_readModel", "Highs_writeModel", "Highs_writePresolvedModel", "Highs_writeSolution", "Highs_writeSolutionPretty", "Highs_readOptions", "Highs_writeOptions", "Highs_writeOptionsDeviations"]
    },
    {
      "family": "lifecycle",
      "exposure": "raw-model",
      "functions": ["Highs_clear", "Highs_clearModel", "Highs_clearSolver", "Highs_releaseMemory", "Highs_presolve", "Highs_run", "Highs_postsolve"]
    },
    {
      "family": "model-input",
      "exposure": "raw-model",
      "functions": ["Highs_passLp", "Highs_passMip", "Highs_passModel", "Highs_passHessian"]
    },
    {
      "family": "linear-objectives",
      "exposure": "raw-model",
      "functions": ["Highs_passLinearObjectives", "Highs_addLinearObjective", "Highs_clearLinearObjectives"]
    },
    {
      "family": "names",
      "exposure": "raw-model",
      "functions": ["Highs_passRowName", "Highs_passColName", "Highs_passModelName", "Highs_getRowName", "Highs_getRowByName", "Highs_getColName", "Highs_getColByName", "Highs_getPresolvedColName", "Highs_getPresolvedRowName"]
    },
    {
      "family": "options",
      "exposure": "raw-model",
      "functions": ["Highs_setBoolOptionValue", "Highs_setIntOptionValue", "Highs_setDoubleOptionValue", "Highs_setStringOptionValue", "Highs_getBoolOptionValue", "Highs_getIntOptionValue", "Highs_getDoubleOptionValue", "Highs_getStringOptionValue", "Highs_getOptionType", "Highs_resetOptions", "Highs_getNumOptions", "Highs_getOptionName", "Highs_getBoolOptionValues", "Highs_getIntOptionValues", "Highs_getDoubleOptionValues", "Highs_getStringOptionValues"]
    },
    {
      "family": "info",
      "exposure": "raw-model",
      "functions": ["Highs_getIntInfoValue", "Highs_getDoubleInfoValue", "Highs_getInt64InfoValue", "Highs_getInfoType"]
    },
    {
      "family": "solution",
      "exposure": "raw-model",
      "functions": ["Highs_getSolution", "Highs_getBasis", "Highs_getModelStatus", "Highs_getDualRay", "Highs_getDualUnboundednessDirection", "Highs_getPrimalRay", "Highs_getObjectiveValue"]
    },
    {
      "family": "basis-analysis",
      "exposure": "raw-model",
      "functions": ["Highs_getBasicVariables", "Highs_getBasisInverseRow", "Highs_getBasisInverseCol", "Highs_getBasisSolve", "Highs_getBasisTransposeSolve", "Highs_getReducedRow", "Highs_getReducedColumn"]
    },
    {
      "family": "warm-start",
      "exposure": "raw-model",
      "functions": ["Highs_setBasis", "Highs_setLogicalBasis", "Highs_setSolution", "Highs_setSparseSolution"]
    },
    {
      "family": "callbacks",
      "exposure": "model-callback-adapter",
      "functions": ["Highs_setCallback", "Highs_startCallback", "Highs_stopCallback", "Highs_getCallbackDataOutItem", "Highs_setCallbackSolution", "Highs_setCallbackSparseSolution", "Highs_repairCallbackSolution"]
    },
    {
      "family": "timing",
      "exposure": "raw-model",
      "functions": ["Highs_getRunTime", "Highs_zeroAllClocks"]
    },
    {
      "family": "add",
      "exposure": "raw-model",
      "functions": ["Highs_addCol", "Highs_addCols", "Highs_addVar", "Highs_addVars", "Highs_addRow", "Highs_addRows"]
    },
    {
      "family": "matrix-orientation",
      "exposure": "raw-model",
      "functions": ["Highs_ensureColwise", "Highs_ensureRowwise"]
    },
    {
      "family": "change-objective",
      "exposure": "raw-model",
      "functions": ["Highs_changeObjectiveSense", "Highs_changeObjectiveOffset"]
    },
    {
      "family": "change-integrality",
      "exposure": "raw-model",
      "functions": ["Highs_changeColIntegrality", "Highs_changeColsIntegralityByRange", "Highs_changeColsIntegralityBySet", "Highs_changeColsIntegralityByMask", "Highs_clearIntegrality"]
    },
    {
      "family": "change-cost",
      "exposure": "raw-model",
      "functions": ["Highs_changeColCost", "Highs_changeColsCostByRange", "Highs_changeColsCostBySet", "Highs_changeColsCostByMask"]
    },
    {
      "family": "change-bounds",
      "exposure": "raw-model",
      "functions": ["Highs_changeColBounds", "Highs_changeColsBoundsByRange", "Highs_changeColsBoundsBySet", "Highs_changeColsBoundsByMask", "Highs_changeRowBounds", "Highs_changeRowsBoundsByRange", "Highs_changeRowsBoundsBySet", "Highs_changeRowsBoundsByMask"]
    },
    {
      "family": "change-coefficient",
      "exposure": "raw-model",
      "functions": ["Highs_changeCoeff"]
    },
    {
      "family": "model-scalars",
      "exposure": "raw-model",
      "functions": ["Highs_getObjectiveSense", "Highs_getObjectiveOffset", "Highs_getColIntegrality", "Highs_getInfinity", "Highs_getSizeofHighsInt", "Highs_getNumCol", "Highs_getNumRow", "Highs_getNumNz", "Highs_getHessianNumNz", "Highs_getPresolvedNumCol", "Highs_getPresolvedNumRow", "Highs_getPresolvedNumNz"]
    },
    {
      "family": "sparse-extraction",
      "exposure": "raw-model",
      "functions": ["Highs_getColsByRange", "Highs_getColsBySet", "Highs_getColsByMask", "Highs_getRowsByRange", "Highs_getRowsBySet", "Highs_getRowsByMask"]
    },
    {
      "family": "delete",
      "exposure": "raw-model",
      "functions": ["Highs_deleteColsByRange", "Highs_deleteColsBySet", "Highs_deleteColsByMask", "Highs_deleteRowsByRange", "Highs_deleteRowsBySet", "Highs_deleteRowsByMask"]
    },
    {
      "family": "scale",
      "exposure": "raw-model",
      "functions": ["Highs_scaleCol", "Highs_scaleRow"]
    },
    {
      "family": "model-extraction",
      "exposure": "raw-model",
      "functions": ["Highs_getModel", "Highs_getLp", "Highs_getPresolvedLp", "Highs_getIisLp", "Highs_getFixedLp"]
    },
    {
      "family": "advanced",
      "exposure": "raw-model",
      "functions": ["Highs_crossover", "Highs_getRanging", "Highs_feasibilityRelaxation", "Highs_getIis"]
    },
    {
      "family": "scheduler",
      "exposure": "excluded",
      "wasmExport": false,
      "functions": ["Highs_resetGlobalScheduler"],
      "reason": "The JavaScript build is single-threaded; exposing global scheduler control adds undefined-behavior risk and no useful capability."
    }
  ],
  "overrides": {
    "Highs_create": {"returnPolicy": "owned-handle", "js": ["raw.createModel", "createModel"], "reason": "Instance ownership is wrapped so destroy is guaranteed."},
    "Highs_destroy": {"returnPolicy": "no-value", "js": ["RawModel.dispose", "Model.dispose"], "reason": "Never expose the native pointer or manual destroy."},
    "Highs_version": {"rawName": "version", "js": ["RawRuntimeApi.version", "Highs.version"]},
    "Highs_versionMajor": {"rawName": "version", "js": ["RawRuntimeApi.version", "Highs.version.major"]},
    "Highs_versionMinor": {"rawName": "version", "js": ["RawRuntimeApi.version", "Highs.version.minor"]},
    "Highs_versionPatch": {"rawName": "version", "js": ["RawRuntimeApi.version", "Highs.version.patch"]},
    "Highs_githash": {"rawName": "version", "js": ["RawRuntimeApi.version", "Highs.version.gitHash"]},
    "Highs_readModel": {"rawName": "readModel", "js": ["RawModel.readModel", "Model.readModel"], "publicInput": "{ data, format: 'lp' | 'mps' }", "reason": "A hidden temporary MEMFS file adapts data; paths are not public."},
    "Highs_writeModel": {"rawName": "exportModel", "js": ["RawModel.exportModel", "Model.exportModel"], "publicInput": "'lp' | 'mps'", "reason": "A hidden temporary MEMFS file is copied out as detached data."},
    "Highs_writePresolvedModel": {"rawName": "exportPresolvedModel", "js": ["RawModel.exportPresolvedModel", "Model.exportPresolvedModel"]},
    "Highs_writeSolution": {"rawName": "exportSolution", "js": ["RawModel.exportSolution", "Model.exportSolution"]},
    "Highs_writeSolutionPretty": {"rawName": "exportSolution", "js": ["RawModel.exportSolution(true)", "Model.exportSolution(true)"]},
    "Highs_readOptions": {"rawName": "readOptions", "js": ["RawModel.readOptions", "Model.options.read"], "publicInput": "string"},
    "Highs_writeOptions": {"rawName": "exportOptions", "js": ["RawModel.exportOptions(false)", "Model.options.export(false)"]},
    "Highs_writeOptionsDeviations": {"rawName": "exportOptions", "js": ["RawModel.exportOptions(true)", "Model.options.export(true)"]},
    "Highs_getRowName": {"js": ["RawModel.getRowName", "Model.getRowName"], "bridge": "length-safe native string shim", "reason": "The upstream API writes with strcpy into a caller buffer and does not accept its size."},
    "Highs_getColName": {"js": ["RawModel.getColName", "Model.getColName"], "bridge": "length-safe native string shim", "reason": "The upstream API writes with strcpy into a caller buffer and does not accept its size."},
    "Highs_getPresolvedRowName": {"bridge": "length-safe native string shim"},
    "Highs_getPresolvedColName": {"bridge": "length-safe native string shim"},
    "Highs_getOptionName": {"ownership": "free returned C allocation after copying"},
    "Highs_setBoolOptionValue": {"rawName": "setOptionValue", "js": ["RawModel.setOptionValue", "Model.options.set"]},
    "Highs_setIntOptionValue": {"rawName": "setOptionValue", "js": ["RawModel.setOptionValue", "Model.options.set"]},
    "Highs_setDoubleOptionValue": {"rawName": "setOptionValue", "js": ["RawModel.setOptionValue", "Model.options.set"]},
    "Highs_setStringOptionValue": {"rawName": "setOptionValue", "js": ["RawModel.setOptionValue", "Model.options.set"]},
    "Highs_getBoolOptionValue": {"rawName": "getOptionValue", "js": ["RawModel.getOptionValue", "Model.options.get"]},
    "Highs_getIntOptionValue": {"rawName": "getOptionValue", "js": ["RawModel.getOptionValue", "Model.options.get"]},
    "Highs_getDoubleOptionValue": {"rawName": "getOptionValue", "js": ["RawModel.getOptionValue", "Model.options.get"]},
    "Highs_getStringOptionValue": {"rawName": "getOptionValue", "js": ["RawModel.getOptionValue", "Model.options.get"]},
    "Highs_getBoolOptionValues": {"rawName": "getOptionValues", "js": ["RawModel.getOptionValues", "Model.options.describe"]},
    "Highs_getIntOptionValues": {"rawName": "getOptionValues", "js": ["RawModel.getOptionValues", "Model.options.describe"]},
    "Highs_getDoubleOptionValues": {"rawName": "getOptionValues", "js": ["RawModel.getOptionValues", "Model.options.describe"]},
    "Highs_getStringOptionValues": {"rawName": "getOptionValues", "js": ["RawModel.getOptionValues", "Model.options.describe"]},
    "Highs_getIntInfoValue": {"rawName": "getInfoValue", "js": ["RawModel.getInfoValue", "Model.info.get"]},
    "Highs_getDoubleInfoValue": {"rawName": "getInfoValue", "js": ["RawModel.getInfoValue", "Model.info.get"]},
    "Highs_getNumOptions": {"returnPolicy": "direct-value"},
    "Highs_getInt64InfoValue": {"rawName": "getInfoValue", "js": ["RawModel.getInfoValue", "Model.info.get"], "jsValue": "bigint"},
    "Highs_getModelStatus": {"returnPolicy": "direct-value"},
    "Highs_getObjectiveValue": {"returnPolicy": "direct-value"},
    "Highs_getRunTime": {"returnPolicy": "direct-value"},
    "Highs_getInfinity": {"returnPolicy": "direct-value"},
    "Highs_getSizeofHighsInt": {"returnPolicy": "direct-value", "js": ["intBytes", "intBits"], "reason": "Avoid the proposal's ambiguous intSize value."},
    "Highs_getNumCol": {"rawName": "getDimensions", "js": ["RawModel.getDimensions", "Model.getDimensions"], "returnPolicy": "direct-value"},
    "Highs_getNumRow": {"rawName": "getDimensions", "js": ["RawModel.getDimensions", "Model.getDimensions"], "returnPolicy": "direct-value"},
    "Highs_getNumNz": {"rawName": "getDimensions", "js": ["RawModel.getDimensions", "Model.getDimensions"], "returnPolicy": "direct-value"},
    "Highs_getHessianNumNz": {"rawName": "getDimensions", "js": ["RawModel.getDimensions", "Model.getDimensions"], "returnPolicy": "direct-value"},
    "Highs_getPresolvedNumCol": {"rawName": "getPresolvedDimensions", "js": ["RawModel.getPresolvedDimensions", "Model.getPresolvedDimensions"], "returnPolicy": "direct-value"},
    "Highs_getPresolvedNumRow": {"rawName": "getPresolvedDimensions", "js": ["RawModel.getPresolvedDimensions", "Model.getPresolvedDimensions"], "returnPolicy": "direct-value"},
    "Highs_getPresolvedNumNz": {"rawName": "getPresolvedDimensions", "js": ["RawModel.getPresolvedDimensions", "Model.getPresolvedDimensions"], "returnPolicy": "direct-value"},
    "Highs_changeColsIntegralityByRange": {"rawName": "changeColsIntegrality", "js": ["RawModel.changeColsIntegrality", "Model.changeColsIntegrality"]},
    "Highs_changeColsIntegralityBySet": {"rawName": "changeColsIntegrality", "js": ["RawModel.changeColsIntegrality", "Model.changeColsIntegrality"]},
    "Highs_changeColsIntegralityByMask": {"rawName": "changeColsIntegrality", "js": ["RawModel.changeColsIntegrality", "Model.changeColsIntegrality"]},
    "Highs_changeColsCostByRange": {"rawName": "changeColsCost", "js": ["RawModel.changeColsCost", "Model.changeColsCost"]},
    "Highs_changeColsCostBySet": {"rawName": "changeColsCost", "js": ["RawModel.changeColsCost", "Model.changeColsCost"]},
    "Highs_changeColsCostByMask": {"rawName": "changeColsCost", "js": ["RawModel.changeColsCost", "Model.changeColsCost"]},
    "Highs_changeColsBoundsByRange": {"rawName": "changeColsBounds", "js": ["RawModel.changeColsBounds", "Model.changeColsBounds"]},
    "Highs_changeColsBoundsBySet": {"rawName": "changeColsBounds", "js": ["RawModel.changeColsBounds", "Model.changeColsBounds"]},
    "Highs_changeColsBoundsByMask": {"rawName": "changeColsBounds", "js": ["RawModel.changeColsBounds", "Model.changeColsBounds"]},
    "Highs_changeRowsBoundsByRange": {"rawName": "changeRowsBounds", "js": ["RawModel.changeRowsBounds", "Model.changeRowsBounds"]},
    "Highs_changeRowsBoundsBySet": {"rawName": "changeRowsBounds", "js": ["RawModel.changeRowsBounds", "Model.changeRowsBounds"]},
    "Highs_changeRowsBoundsByMask": {"rawName": "changeRowsBounds", "js": ["RawModel.changeRowsBounds", "Model.changeRowsBounds"]},
    "Highs_getColsByRange": {"rawName": "getCols", "js": ["RawModel.getCols", "Model.getCols"]},
    "Highs_getColsBySet": {"rawName": "getCols", "js": ["RawModel.getCols", "Model.getCols"]},
    "Highs_getColsByMask": {"rawName": "getCols", "js": ["RawModel.getCols", "Model.getCols"]},
    "Highs_getRowsByRange": {"rawName": "getRows", "js": ["RawModel.getRows", "Model.getRows"]},
    "Highs_getRowsBySet": {"rawName": "getRows", "js": ["RawModel.getRows", "Model.getRows"]},
    "Highs_getRowsByMask": {"rawName": "getRows", "js": ["RawModel.getRows", "Model.getRows"]},
    "Highs_deleteColsByRange": {"rawName": "deleteCols", "js": ["RawModel.deleteCols", "Model.deleteCols"]},
    "Highs_deleteColsBySet": {"rawName": "deleteCols", "js": ["RawModel.deleteCols", "Model.deleteCols"]},
    "Highs_deleteColsByMask": {"rawName": "deleteCols", "js": ["RawModel.deleteCols", "Model.deleteCols"]},
    "Highs_deleteRowsByRange": {"rawName": "deleteRows", "js": ["RawModel.deleteRows", "Model.deleteRows"]},
    "Highs_deleteRowsBySet": {"rawName": "deleteRows", "js": ["RawModel.deleteRows", "Model.deleteRows"]},
    "Highs_deleteRowsByMask": {"rawName": "deleteRows", "js": ["RawModel.deleteRows", "Model.deleteRows"]},
    "Highs_setCallback": {"rawName": "setCallback", "js": ["RawModel.setCallback", "Model.run callback setup"], "bridge": "callback-type-safe native shim", "reason": "The upstream C adapter copies uninitialized fields for logging callbacks and supplies an invalid data-in pointer when none exists."},
    "Highs_startCallback": {"rawName": "startCallback", "js": ["RawModel.startCallback", "Model.run callback setup"]},
    "Highs_stopCallback": {"js": ["RawModel.stopCallback", "Model.run callback cleanup"]},
    "Highs_getCallbackDataOutItem": {"rawName": null, "returnPolicy": "copied-by-callback-adapter", "reason": "Callback payloads are copied by the trampoline; raw callback-data pointers never escape."},
    "Highs_setCallbackSolution": {"rawName": null, "js": ["CallbackControl.setSolution"]},
    "Highs_setCallbackSparseSolution": {"rawName": null, "js": ["CallbackControl.setSparseSolution"]},
    "Highs_repairCallbackSolution": {"rawName": null, "js": ["CallbackControl.repairSolution"]},
    "Highs_resetGlobalScheduler": {"rawName": null, "returnPolicy": "not-exposed", "js": []}
  },
  "compatibilityExports": ["_Highs_call"],
  "generatedExports": ["_malloc", "_free"],
  "bridgeExports": ["_Highs_js_getColName", "_Highs_js_getRowName", "_Highs_js_getPresolvedColName", "_Highs_js_getPresolvedRowName", "_Highs_js_setCallback"]
}
