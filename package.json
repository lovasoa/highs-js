{
  "name": "highs",
  "version": "1.15.3-pre.2",
  "description": "Mixed integer linear programming library, built by compiling a high-performance C++ solver developed by the University of Edinburgh (HiGHS) to WebAssembly.",
  "main": "build/highs.js",
  "module": "build/highs.mjs",
  "type": "commonjs",
  "exports": {
    ".": {
      "types": "./types.d.ts",
      "import": "./build/highs.mjs",
      "require": "./build/highs.js",
      "default": "./build/highs.js"
    },
    "./runtime": "./build/highs.wasm",
    "./legacy-types": "./types.d.ts"
  },
  "types": "types.d.ts",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "tsc && tsc -p tsconfig.runtime.json && tsc -p test-dts/tsconfig.json && node tests/test.js && node --test tests/extended/*.test.cjs",
    "test:package": "node scripts/test-packed-package.mjs",
    "test:demo": "node scripts/test-demo.mjs",
    "build:demo": "node scripts/prepare-demo.mjs && npm run docs:api",
    "build": "./build.sh",
    "check:api": "node scripts/generate-highs-api.mjs --check",
    "docs:options": "node scripts/generate-options-docs.mjs",
    "docs:api": "npm ci --prefix docs-tooling --ignore-scripts && node docs-tooling/node_modules/typedoc/bin/typedoc --options typedoc.json",
    "bench:runtime": "node benchmarks/runtime.mjs",
    "bench:size": "node benchmarks/measure-size.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lovasoa/highs-js.git"
  },
  "keywords": [
    "linear programming",
    "LP",
    "MILP",
    "solver",
    "maths",
    "or",
    "optimization"
  ],
  "author": "Ophir LOJKINE",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/lovasoa/highs-js/issues"
  },
  "homepage": "https://lovasoa.github.io/highs-js/",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@tsconfig/recommended": "^1.0.13",
    "playwright": "^1.49.0",
    "typescript": "^7.0.2"
  },
  "files": [
    "build/highs.js",
    "build/highs.mjs",
    "build/highs.wasm",
    "package.json",
    "types.d.ts",
    "api/highs-c-api.generated.json",
    "HiGHS/LICENSE.txt",
    "HiGHS/THIRD_PARTY_NOTICES.md",
    "docs",
    "README.md"
  ]
}
